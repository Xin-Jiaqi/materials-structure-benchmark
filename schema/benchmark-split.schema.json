{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Xin-Jiaqi/materials-structure-benchmark/schema/benchmark-split.schema.json",
  "title": "Materials Structure Benchmark split",
  "type": "object",
  "required": ["schema_version", "id", "tier", "description", "scientific_boundary", "records"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^batch-[a-z]+-v[0-9]+$"},
    "tier": {"enum": ["smoke", "small", "medium"]},
    "description": {"type": "string", "minLength": 1},
    "parent_split": {"type": "string", "pattern": "^batch-[a-z]+-v[0-9]+$"},
    "scientific_boundary": {"type": "string", "minLength": 1},
    "selection_policy": {"type": "object"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "sha256", "structure_type", "license", "selection_reason"],
        "properties": {
          "id": {"type": "string", "pattern": "^mst-[a-z0-9-]+-[0-9]{6}$"},
          "path": {"type": "string", "pattern": "^structures/.+\\.vasp$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "structure_type": {"enum": ["monolayer", "bulk"]},
          "license": {"type": "string", "minLength": 1},
          "selection_reason": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
